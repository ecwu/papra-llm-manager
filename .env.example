# Papra API
PAPRA_BASE_URL=https://api.papra.ai/v1
PAPRA_API_TOKEN=your_papra_api_token
PAPRA_ORG_ID=your_papra_organization_id

# LLM Configuration (provider/model format)
# Examples:
#   anthropic/claude-3-5-sonnet-20241022
#   openai/gpt-4o
#   ollama/llava
#   deepseek/deepseek-chat
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
LLM_API_KEY=your_llm_api_key

# Optional: Custom API base (required for Ollama, Azure, proxies)
# LLM_API_BASE=http://localhost:11434